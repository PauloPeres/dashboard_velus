# =============================================================================
# Velus Dashboard — variáveis de ambiente (exemplo)
# =============================================================================
# Copie para .env e ajuste para seu ambiente local.
# .env NUNCA vai pro repo (gitignored).
# Em produção, todos esses valores vêm de K8s Secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
DJANGO_ENV=development                          # development | production | test
DJANGO_SECRET_KEY=change-me-dev-only-not-for-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=America/Sao_Paulo
DJANGO_LANGUAGE_CODE=pt-br

# -----------------------------------------------------------------------------
# Database (Postgres 16)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://velus:velus@localhost:5432/velus_dashboard

# -----------------------------------------------------------------------------
# Cache & broker (Redis 7)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# Criptografia — Fernet (credenciais IXC e similares no DB)
# -----------------------------------------------------------------------------
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Em produção: vem de K8s Secret SEPARADO do Postgres password. Rotacionável.
FERNET_KEY=change-me-generate-with-fernet

# -----------------------------------------------------------------------------
# Google OAuth (django-allauth)
# -----------------------------------------------------------------------------
# Console: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (dev: console; prod: SMTP real)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Velus Dashboard <noreply@velus.local>

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=console                              # console (dev) | json (prod)

# -----------------------------------------------------------------------------
# Observabilidade (opcional em dev)
# -----------------------------------------------------------------------------
# SENTRY_DSN=
