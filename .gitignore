# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Claude Code / agentes — config local não vai pro repo
# -----------------------------------------------------------------------------
.claude/

