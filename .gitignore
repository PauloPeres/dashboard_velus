# =============================================================================
# Velus Dashboard — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets — NUNCA commitar
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*secrets.env
velus_secrets.env
secrets/
*.key
*.pem
*.p12
*.pfx
fernet.key

# Postman collections — ignoradas por padrão (frequentemente vazam credenciais
# como Basic auth literal ou tokens em texto plano).
# A collection do IXC NESTE repo foi sanitizada manualmente (tokens, IXC_Session,
# emails, CPFs e hashes de senha substituídos por variáveis/placeholders) e está
# liberada via exceção (!) abaixo. Ao adicionar novas collections, rodar scan
# antes de remover do gitignore.
*.postman_collection.json
*.postman_environment.json
!API - IXC Provedor.postman_collection.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
develop-eggs/
.eggs/
sdist/
wheels/
share/python-wheels/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Virtual envs
.venv/
venv/
env/
ENV/
.python-version

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
*.sqlite3
*.sqlite3-journal
db.sqlite3
local_settings.py
staticfiles/
media/

# Logs
*.log
logs/

# Celery
celerybeat-schedule
celerybeat.pid

